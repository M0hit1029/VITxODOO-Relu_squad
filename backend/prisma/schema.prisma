generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

enum UserRole {
  admin
  manager
  employee
}

enum ExpenseStatus {
  draft
  submitted
  approved
  rejected
}

enum ApprovalStatus {
  pending
  approved
  rejected
}

model Company {
  id             String         @id @default(uuid())
  name           String
  country        String
  base_currency  String         @db.VarChar(3)
  created_at     DateTime       @default(now())
  users          User[]
  expenses       Expense[]
  approval_rules ApprovalRule[]
}

model User {
  id                        String                 @id @default(uuid())
  company_id                String
  name                      String
  email                     String                 @unique
  password_hash             String
  role                      UserRole
  manager_id                String?
  reset_token               String?
  reset_token_expiry        DateTime?
  created_at                DateTime               @default(now())
  company                   Company                @relation(fields: [company_id], references: [id])
  manager                   User?                  @relation("UserManager", fields: [manager_id], references: [id])
  subordinates              User[]                 @relation("UserManager")
  expenses                  Expense[]
  approval_rule_approvers   ApprovalRuleApprover[]
  approval_requests         ApprovalRequest[]
  expense_logs              ExpenseLog[]
  approval_rules            ApprovalRule[]         @relation("ApprovalRuleUser")
  managed_approval_rules    ApprovalRule[]         @relation("ApprovalRuleManager")
}

model Expense {
  id                String            @id @default(uuid())
  company_id        String
  employee_id       String
  description       String
  category          String
  expense_date      DateTime
  amount            Decimal           @db.Decimal(12, 2)
  currency          String            @db.VarChar(3)
  amount_in_base    Decimal?          @db.Decimal(12, 2)
  paid_by           String
  remarks           String?
  receipt_url       String?
  status            ExpenseStatus
  created_at        DateTime          @default(now())
  updated_at        DateTime          @updatedAt
  company           Company           @relation(fields: [company_id], references: [id])
  employee          User              @relation(fields: [employee_id], references: [id])
  approval_requests ApprovalRequest[]
  expense_logs      ExpenseLog[]
}

model ApprovalRule {
  id                      String                 @id @default(uuid())
  company_id              String
  user_id                 String
  description             String
  manager_id              String?
  is_manager_approver     Boolean                @default(false)
  approvers_sequence      Boolean                @default(false)
  min_approval_percentage Int                    @default(100)
  created_at              DateTime               @default(now())
  company                 Company                @relation(fields: [company_id], references: [id])
  user                    User                   @relation("ApprovalRuleUser", fields: [user_id], references: [id])
  manager                 User?                  @relation("ApprovalRuleManager", fields: [manager_id], references: [id])
  approvers               ApprovalRuleApprover[]
  approval_requests       ApprovalRequest[]
}

model ApprovalRuleApprover {
  id             String       @id @default(uuid())
  rule_id        String
  user_id        String
  sequence_order Int
  is_required    Boolean      @default(false)
  rule           ApprovalRule @relation(fields: [rule_id], references: [id])
  user           User         @relation(fields: [user_id], references: [id])
}

model ApprovalRequest {
  id             String         @id @default(uuid())
  expense_id     String
  approver_id    String
  rule_id        String
  status         ApprovalStatus
  comments       String?
  sequence_order Int
  is_required    Boolean        @default(false)
  decided_at     DateTime?
  created_at     DateTime       @default(now())
  expense        Expense        @relation(fields: [expense_id], references: [id])
  approver       User           @relation(fields: [approver_id], references: [id])
  rule           ApprovalRule   @relation(fields: [rule_id], references: [id])
}

model ExpenseLog {
  id        String   @id @default(uuid())
  expense_id String
  actor_id  String
  action    String
  note      String?
  timestamp DateTime @default(now())
  expense   Expense  @relation(fields: [expense_id], references: [id])
  actor     User     @relation(fields: [actor_id], references: [id])
}
